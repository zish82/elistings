@inject Client.Services.AuthService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">eListings</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="create-listing">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Create Listing
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bulk-extract">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Bulk Extract
            </NavLink>
        </div>
        @if (canManageUsers)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="users">
                    <span class="bi bi-people-fill" aria-hidden="true"></span> Users
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool canManageUsers;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthService.GetSessionAsync();
        canManageUsers = session.User?.CanManageUsers == true;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
